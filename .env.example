# ── WILDBIRD Catering Ops — Environment Variables ────────────────────
# Copy this file to .env.local and fill in the values.

# ── NextAuth ─────────────────────────────────────────────────────────
# [REQUIRED] Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# [REQUIRED] Your app URL (http://localhost:3000 for dev)
NEXTAUTH_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string (Supabase pooler recommended)
# Use the "Transaction" pooler string (port 6543) for Vercel serverless
DATABASE_URL=postgresql://postgres:password@host:6543/postgres?pgbouncer=true

# ── Supabase Storage ────────────────────────────────────────────────
# [REQUIRED] For PDF, label, and photo file storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Google Service Account ──────────────────────────────────────────
# [OPTIONAL] For Gmail sending and Google Sheets integration
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GMAIL_SENDER_EMAIL=hello@eatwildbird.com

# ── Integrations ────────────────────────────────────────────────────
# [OPTIONAL] Slack webhook for order notifications
SLACK_WEBHOOK_URL=

# [OPTIONAL] Web Push (VAPID) keys for push notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
